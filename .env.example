# Copy to .env to enable real flight data. The app prefers AirLabs, then
# OpenSky, then the bundled sample flights — based on which keys are set.
#
# ── Recommended: AirLabs (real *scheduled* departures + delay status) ──────────
# 1. Sign up free at https://airlabs.co/signup (no credit card; 1,000 req/month).
# 2. Copy your API key from the dashboard into the value below.
# 3. Restart the server. The dashboard subtitle reads "Live flights (AirLabs)".
#
FDP_AIRLABS_API_KEY=your_airlabs_api_key_here

# ── Alternative: OpenSky Network (historical departures, OAuth2) ───────────────
# Create a free account at https://opensky-network.org/ -> Account -> API Client.
# FDP_OPENSKY_CLIENT_ID=your_client_id_here
# FDP_OPENSKY_CLIENT_SECRET=your_client_secret_here

# ── Optional overrides ─────────────────────────────────────────────────────────
# FDP_FLIGHT_SOURCE=auto          # auto | mock | airlabs | opensky
# FDP_HIGH_RISK_THRESHOLD=70
# FDP_AIRLABS_PER_HUB_LIMIT=8
# FDP_OPENSKY_PER_HUB_LIMIT=8
